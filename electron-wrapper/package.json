{
  "name": "astron-local-kb-desktop",
  "version": "1.6.0",
  "description": "本地知识库桌面客户端（anything-llm + astron /knowledge/v1 适配器）",
  "main": "main.js",
  "author": "astron",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux --publish never"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.astron.localkb",
    "productName": "AstronLocalKB",
    "electronVersion": "31.7.7",
    "npmRebuild": false,
    "publish": null,
    "files": [
      "main.js",
      "package.json",
      "astron-env.json"
    ],
    "extraResources": [
      {
        "from": "payload",
        "to": "app"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  }
}
